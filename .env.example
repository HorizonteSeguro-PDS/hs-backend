# Copy this file to .env and replace the placeholder values.
DATABASE_URL=postgresql+psycopg://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_HOST:5432/CHANGE_ME_DATABASE
JWT_SECRET=CHANGE_ME_SECRET
# Optional — defaults are HS256 and 24 hours.
JWT_ALGORITHM=HS256
JWT_EXPIRES_HOURS=24
TEST_DATABASE_URL=postgresql+psycopg://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_HOST:5432/CHANGE_ME_TEST_DATABASE

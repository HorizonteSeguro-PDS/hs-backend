# Copy this file to .env and replace the placeholder values.
DATABASE_URL=postgresql+psycopg://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_HOST:5432/CHANGE_ME_DATABASE
JWT_SECRET=CHANGE_ME_SECRET
# Optional — defaults are HS256 and 24 hours.
JWT_ALGORITHM=HS256
JWT_EXPIRES_HOURS=24
TEST_DATABASE_URL=postgresql+psycopg://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_HOST:5432/CHANGE_ME_TEST_DATABASE

# CORS — vírgula-separado. Em dev local, deixe vazio que o backend usa
# localhost:3000/5173/8080 por default. Em produção (Render), defina explicitamente
# os domínios do frontend. Use "*" pra liberar tudo (OK pra MVP com JWT em header).
CORS_ALLOWED_ORIGINS=https://hs-frontend.vercel.app,http://localhost:3000
# Opcional — regex pra preview URLs dinâmicas da Vercel.
# CORS_ALLOW_ORIGIN_REGEX=https://hs-frontend-.*\.vercel\.app
